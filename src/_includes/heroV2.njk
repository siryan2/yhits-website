<section class="hero hero--v2">
  <div class="hero-inner container-small">
    <div class="hero__content-container">
      <p class="color-brand-secondary font-brand-mono text-uppercase font--small">&mdash; Full-Stack-Entwickler · Offenburg</p>
      <h1 class="hero__headline mt-1">Anspruchsvolle Webprojekte —<br/> von der <span class="hero__highlight">Architektur</span> bis zum Betrieb.</h1>
      <p class="hero__subheadline">Seit über 15 Jahren entwickle ich als selbstständiger Full-Stack-Entwickler und Fractional CTO Software, die hält. Für KMU, Agenturen und Startups — technisch fundiert, langfristig gedacht.</p>
      <div class="hero__btn-group">
        <a href="/projekte/" class="btn btn-primary btn-primary--round flex align-center gap-1">
          <span>Projekte ansehen</span>
          {% include "icon/arrow-right.njk" %}
        </a>
        <a href="/kontakt.html" class="btn btn-ghost">Jetzt anfragen</a>
      </div>

      <div class="hero__meta">
        <div class="hero__meta-item">
          <div class="n">15+</div>
          <div class="l">Jahre Erfahrung</div>
        </div>
        <div class="hero__meta-item">
          <div class="n">2017</div>
          <div class="l">längste Partnerschaft</div>
        </div>
        <div class="hero__meta-item">
          <div class="n">CTO</div>
          <div class="l">Rolle &amp; Mindset</div>
        </div>
      </div>
    </div>

    <div class="hero__image-container">
      {% include "code-card.njk" %}
    </div>
  </div>
</section>
